# Copy to .env for local runs. In CI these live in GitHub Actions secrets, not here.

# --- Content generation (used by `pnpm gen`) ---
# Single Google Gemini API key from Google AI Studio (https://aistudio.google.com).
# Used for BOTH the caption (gemini.ts) and the image (image.ts).
GEMINI_API_KEY=AIza...

# Optional model overrides (sensible defaults are in the code):
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Publishing (used by `pnpm publish:posts`) ---
# Instagram Business/Creator account ID (the IG user id, NOT the @handle).
IG_USER_ID=1784xxxxxxxxxxx
# Long-lived access token with instagram_basic + instagram_content_publish + pages_read_engagement.
IG_ACCESS_TOKEN=EAAxxxxxxxx

# Set automatically by GitHub Actions; only needed locally if you test publishing.
# Format: owner/repo  — used to build the public raw image URL for the Graph API.
GITHUB_REPOSITORY=your-org/harvona-ig-agent
