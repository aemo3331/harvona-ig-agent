{
  "name": "harvona-ig-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI content agent for the @harvona_international_ai Instagram account: generates image + caption, queues for review via PR, publishes via the Instagram Graph API.",
  "scripts": {
    "gen": "tsx src/generate.ts",
    "publish:posts": "tsx src/publish.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@google/genai",
      "protobufjs"
    ]
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "sharp": "^0.35.2"
  }
}
